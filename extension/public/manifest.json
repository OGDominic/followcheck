{
  "manifest_version": 3,
  "name": "FollowCheck",
  "version": "0.1.0",
  "description": "Analyze follower and following connections to discover mutuals and non-followers on Instagram.",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "*://*.instagram.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://www.whofollowsback.com/*",
      "https://whofollowsback.com/*"
    ]
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open FollowCheck",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
